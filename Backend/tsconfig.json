{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "tests/categoria.service.test.ts", "tests/estados.service.test.ts", "tests/marcas.service.test.ts", "tests/productos.service.test.ts"],
  "exclude": ["node_modules"]
}
